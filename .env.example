# UKKIN — seat keys. Copy this file to .env and fill in what you have.
# A seat lights up only if its key is present. You do not need all of them;
# one key (or a local Ollama) is enough to convene the room.
# .env is gitignored. Keys never leave your machine except to the provider itself.

# Who holds the gold seat (your name, shown in the room)
UKKIN_HOST=Host

# Claude (Anthropic) — https://console.anthropic.com
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# ChatGPT (OpenAI) — https://platform.openai.com
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.6-terra   (tiers: gpt-5.6-sol / -terra / -luna)

# Grok (xAI) — https://console.x.ai
XAI_API_KEY=
# XAI_MODEL=grok-4.5

# Kimi (Moonshot) — https://platform.moonshot.ai
MOONSHOT_API_KEY=
# MOONSHOT_MODEL=kimi-k3

# Gemini (Google) — https://aistudio.google.com
GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-3-flash-preview   (works on the free tier; 2.5-pro needs paid quota)

# DeepSeek — https://platform.deepseek.com
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat

# Perplexity (the table's researcher) — https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=
# PPLX_MODEL=sonar-pro

# Local model via Ollama — no key needed; just have Ollama running
# OLLAMA_BASE=http://localhost:11434/v1
# OLLAMA_MODEL=qwen3.6:27b

# Room settings
# UKKIN_PORT=8787
# UKKIN_MAX_TOKENS=4096
